// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  name        String?
  email       String   @unique
  password    String?   // nullable désormais
  authMethod  String?   // 'CREDENTIALS' | 'GOOGLE' — null tant que non activé
  status      String    @default("PENDING") // PENDING, ACTIVE
  role        String   @default("RECEPTIONIST") // ADMIN, DG, RECEPTIONIST
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  entries        Entry[]
  cashMovements  CashMovement[]
  stockMovements StockMovement[]
  closures       Closure[] @relation("ClosureUser")
  validations    Closure[] @relation("ClosureValidator")
}

model ActivationToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique   // sha256 du vrai token, jamais le token en clair en base
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
}

model Room {
  id        String   @id @default(cuid())
  num       String   @unique
  type      String   // V (Ventilée), C (Climée), A (Appart)
  label     String
  price     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String   @default("DRINK") // DRINK, CONDOM
  price     Float
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  entries   EntryProduct[]
  movements StockMovement[]
}

model Entry {
  id           String   @id @default(cuid())
  receiptNo    String?
  roomNum      String
  roomType     String
  roomTypeLabel String
  arrival      String?
  departure    String?
  duration     String?
  roomAmount   Float    @default(0)
  condomAmount Float    @default(0)
  drinksAmount Float    @default(0)
  total        Float    @default(0)
  
  date         String   // YYYY-MM-DD for easy filtering
  
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  
  closureId    String?
  closure      Closure? @relation(fields: [closureId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products     EntryProduct[]
}

model EntryProduct {
  id        String @id @default(cuid())
  qty       Int
  price     Float
  
  entryId   String
  entry     Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  
  productId String
  product   Product  @relation(fields: [productId], references: [id])
}

model CashMovement {
  id        String   @id @default(cuid())
  label     String
  amount    Float
  type      String   // 'depense' or 'recette'
  date      String   // YYYY-MM-DD
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  closureId String?
  closure   Closure? @relation(fields: [closureId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockMovement {
  id        String   @id @default(cuid())
  type      String   // 'IN' or 'OUT'
  qty       Int
  price     Float?
  motif     String?  // Obligatoire pour 'OUT'
  date      String   // YYYY-MM-DD
  
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Closure {
  id             String   @id @default(cuid())
  date           String   // YYYY-MM-DD ou 'YYYY-Wxx'
  type           String   // 'DAILY' or 'WEEKLY'
  
  userId         String
  user           User     @relation("ClosureUser", fields: [userId], references: [id])
  
  expectedAmount Float
  handedAmount   Float?
  discrepancy    Float?
  comments       String?
  status         String   @default("PENDING") // PENDING, VALIDATED
  
  validatedById  String?
  validatedBy    User?    @relation("ClosureValidator", fields: [validatedById], references: [id])
  
  entries        Entry[]
  cashMovements  CashMovement[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, date, type])
}

model OtpCode {
  id         String    @id @default(cuid())
  email      String
  code       String
  purpose    String    // 'LOGIN' or 'SIGNUP'
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
}

model AccessRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String?
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // 'CREATE_ENTRY', 'UPDATE_ENTRY', 'DELETE_ENTRY'
  entityId  String
  details   String
  userId    String
  createdAt DateTime @default(now())
}
